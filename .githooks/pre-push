#!/usr/bin/env bash
# SPDX-License-Identifier: BSD-2-Clause
# pre-push gate: tag-format enforcement.
# Pattern: <repo-name>-v<n> — derived from git remote, not hardcoded.
# Rule: memory.db rule 37 (tag-format-gate).
set -euo pipefail

# Derive repo name from origin remote URL
REPO_NAME=$(git remote get-url origin 2>/dev/null | sed 's/.*\///' | sed 's/\.git$//')

# Tag must match <repo-name>-v<n>
VALID_RE="^refs/tags/${REPO_NAME}-v[0-9]+\$"

rc=0
while read local_ref local_oid remote_ref remote_oid; do
    case "$local_ref" in
        refs/tags/*)
            if ! echo "$local_ref" | grep -qE "$VALID_RE"; then
                echo "GATE FAIL [tag-format]: '$local_ref' does not match ${REPO_NAME}-v<n>"
                echo "  Expected pattern: ${REPO_NAME}-vN"
                rc=1
            fi
            ;;
    esac
done

exit $rc
